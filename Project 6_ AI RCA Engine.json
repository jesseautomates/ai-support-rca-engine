      "parameters": {
        "jsCode": "const summary = items.find(i => i.json.root_cause_summary)?.json;\n\nconst tickets = items\n  .filter(i => i.json.ticket_id)\n  .map(i => i.json);\n\nreturn [\n  {\n    json: {\n      total_matched_tickets: summary?.total_matched_tickets || 0,\n      root_cause_summary: summary?.root_cause_summary || [],\n      tickets: tickets\n    }\n  }\n];"
      },
