    {
      "parameters": {
        "jsCode": "const totalTickets = items.length;\n\nconst bucketCounts = {};\n\nfor (const item of items) {\n  const bucket = item.json.root_cause_bucket || 'Unknown';\n\n  if (!bucketCounts[bucket]) {\n    bucketCounts[bucket] = 0;\n  }\n\n  bucketCounts[bucket]++;\n}\n\n// Optional: sort buckets by count (highest first)\nconst sortedBuckets = Object.entries(bucketCounts)\n  .sort((a, b) => b[1] - a[1])\n  .map(([bucket, count]) => ({ bucket, count }));\n\nreturn [\n  {\n    json: {\n      total_matched_tickets: totalTickets,\n      root_cause_summary: sortedBuckets\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        -112
      ],
      "id": "75e1746c-31f0-4d13-95cc-5bafdcee0815",
      "name": "Summarize the Matches"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let updatedRootCause = item.json.root_cause_bucket;\n\n  if (updatedRootCause === 'Billing Configuration Error') {\n    updatedRootCause = 'Billing System Issue';\n  }\n\n  return {\n    json: {\n      ...item.json,\n      root_cause_bucket: updatedRootCause\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
