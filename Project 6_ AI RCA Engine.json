      "parameters": {
        "jsCode": "return items.map(item => {\n  const predicted = (item.json.root_cause_bucket || '').trim().toLowerCase();\n  const actual = (item.json.true_root_cause || '').trim().toLowerCase();\n\n  const isCorrect = predicted === actual;\n\n  return {\n    json: {\n      ...item.json,\n      validation_result: isCorrect ? 'Match' : 'Mismatch',\n      is_correct: isCorrect,\n    }\n  };\n});"
      },
