      "parameters": {
        "jsCode": "return items.map(item => {\n  try {\n    const rawText =\n      item.json.output?.[0]?.content?.[0]?.text || '';\n\n    const parsed = JSON.parse(rawText);\n\n    return {\n      json: {\n        ...item.json,\n        root_cause_bucket: parsed.root_cause_bucket || null,\n        confidence: parsed.confidence || null,\n        reasoning: parsed.reasoning || null,\n        recommended_action: parsed.recommended_action || null,\n        parse_success: true,\n      }\n    };\n  } catch (error) {\n    return {\n      json: {\n        ...item.json,\n        root_cause_bucket: null,\n        confidence: null,\n        reasoning: null,\n        recommended_action: null,\n        parse_success: false,\n        parse_error: error.message,\n      }\n    };\n  }\n});"
      },
